# AIOps 环境变量配置
# 复制此文件为 .env 并修改相应配置

# ==================== 配置 (AIOPS_ 前缀) ====================
# 配置系统使用 AIOPS_ 前缀的环境变量 (双下划线分隔层级)
AIOPS_ENVIRONMENT=dev
AIOPS_LOG_LEVEL=INFO
AIOPS_DATA_DIR=data

# 监控配置
AIOPS_METRICS__PROMETHEUS_BASE_URL=http://prometheus:9090
AIOPS_METRICS__OTEL_METRICS_QUERY_URL=http://otel-collector:8889
AIOPS_METRICS__CPU_THRESHOLD=80.0
AIOPS_METRICS__MEMORY_THRESHOLD=80.0
AIOPS_METRICS__DISK_THRESHOLD=80.0

# 日志配置
AIOPS_LOGS__VICTORIALOGS_BASE_URL=http://victorialogs:9428
AIOPS_LOGS__OTEL_LOGS_QUERY_URL=http://otel-collector:4318
AIOPS_LOGS__LOG_TYPE=syslog
AIOPS_LOGS__MAX_LINES=200

# 安全配置
AIOPS_SECURITY__HUMAN_APPROVAL_REQUIRED=true
AIOPS_SECURITY__APPROVAL_WEBHOOK_URL=

# Skills configuration
AIOPS_SKILLS__BASE_DIR=~/.aiops
AIOPS_SKILLS__QUALITY_THRESHOLD=0.7
AIOPS_SKILLS__SCAN_ENABLED=true
AIOPS_SKILLS__AUTO_REGISTER=true
AIOPS_SKILLS__MAX_SIZE_MB=10
AIOPS_SKILLS__ALLOWED_CATEGORIES=monitoring,diagnosis,remediation,security,reporting,custom

# ==================== 新功能配置 (直接环境变量) ====================
# 向量数据库 (ChromaDB) - 用于知识库
CHROMADB_URL=http://chromadb:8000
CHROMADB_COLLECTION=aiops_knowledge

# Redis缓存 - 用于技能执行缓存和会话管理
REDIS_URL=redis://redis:6379/0
REDIS_CACHE_TTL=3600

# Agent Skills 配置
SKILL_REGISTRY_TYPE=memory  # memory, database
SKILL_DISCOVERY_ENABLED=true

# LLM 配置 (可选)
OPENAI_API_KEY=
OPENAI_BASE_URL=http://localhost:11434/v1  # 本地Ollama
OPENAI_MODEL=gpt-4-turbo-preview

# 知识库配置
KNOWLEDGE_UPDATE_SCHEDULE=0 2 * * *  # 每天凌晨2点
KNOWLEDGE_RETENTION_DAYS=90

# 开发设置
DEBUG=true
RELOAD=true

LANGCHAIN_TRACING_V2=true
LANGCHAIN_TRACING=true
LANGSMITH_API_KEY=lsv2_pt_xxxx
LANGSMITH_ENDPOINT=https://eu.api.smith.langchain.com
LANGSMITH_PROJECT="aiops"
